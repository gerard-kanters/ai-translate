{
    "name": "ai-translate/ai-translate",
    "description": "AI Translate WordPress plugin - development dependencies",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload-dev": {
        "psr-4": {
            "AITranslate\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite Unit"
    },
    "config": {
        "allow-plugins": {},
        "sort-packages": true
    }
}
